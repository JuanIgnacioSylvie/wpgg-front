{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/build-web-vercel.sh",
  "outputDirectory": "build/web",
  "installCommand": "npm install && if ! command -v flutter >/dev/null 2>&1; then git clone https://github.com/flutter/flutter.git -b stable --depth 1 /tmp/flutter && export PATH=\"/tmp/flutter/bin:$PATH\"; fi && flutter pub get",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.wpgg.lol" }],
      "destination": "https://wpgg.lol/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "text/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!robots\\.txt|sitemap\\.xml|favicon\\.ico|favicon\\.png|icons/|firebase-messaging-sw\\.js|firebase-config\\.js|_vercel/).*)",
      "destination": "/index.html"
    }
  ]
}
